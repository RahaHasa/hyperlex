# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/hyperlex

# JWT Secret (используй криптографически безопасный ключ на production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Configuration
NODE_ENV=development
PORT=3001

# API URL (для корреляции с фронтендом)
API_URL=http://localhost:3001

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Admin Credentials (для seed скрипта)
ADMIN_EMAIL=admin@hyperlex.com
ADMIN_PASSWORD=admin123
